# Twake Team Health — configuration template. Copy to .env and fill in.
# Do NOT commit a real .env (it is git-ignored).

# Read-only GitHub token used for every query (fine-grained, read scopes only).
GITHUB_TOKEN=

# Organizations whose members and repositories are selectable.
ALLOWED_ORGS=octocat

# Preset teams shared with everyone (JSON array). Real rosters belong here, not in code.
DEFAULT_TEAMS=[{"name":"Platform","members":[{"login":"octocat","name":"The Octocat"}],"repos":[{"owner":"octocat","repo":"Hello-World"}]}]

# Data stores.
DATABASE_URL=postgres://teamhealth:teamhealth@localhost:5432/teamhealth
REDIS_URL=redis://localhost:6379

# Caching / GitHub load (all optional, sensible defaults shown).
# How long the in-progress month's data is reused before re-fetching from GitHub.
# Completed months are persisted once and never re-fetched. Set 0 to always refetch.
# CURRENT_MONTH_TTL_MS=21600000
# Assembled-report cache TTL (Redis or in-memory).
# METRICS_CACHE_TTL_MS=1200000
# Org repo/member discovery cache TTL.
# DISCOVERY_CACHE_TTL_MS=21600000

# Secret for the cache warmer. When set, a scheduler can keep the data warm by
# calling POST /api/cron/warm with "Authorization: Bearer <CRON_SECRET>" (e.g.
# every few hours). Unset = the endpoint stays disabled (401).
# CRON_SECRET=

# Auth. Leave AUTH_DISABLED unset in production and configure OIDC.
# AUTH_DISABLED=true
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
AUTH_SECRET=
ORIGIN=http://localhost:3000

# Admins (OIDC subjects, comma-separated) who can edit app-wide settings at
# /settings. Unset = nobody can (settings stay env-only). Ignored when auth is
# disabled (the dev user is admin).
# ADMIN_SUBS=
