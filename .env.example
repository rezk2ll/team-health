# Twake Team Health — configuration template. Copy to .env and fill in.
# Do NOT commit a real .env (it is git-ignored).

# Read-only GitHub token used for every query (fine-grained, read scopes only).
GITHUB_TOKEN=

# Organizations whose members and repositories are selectable.
ALLOWED_ORGS=octocat

# Preset teams shared with everyone (JSON array). Real rosters belong here, not in code.
DEFAULT_TEAMS=[{"name":"Platform","members":[{"login":"octocat","name":"The Octocat"}],"repos":[{"owner":"octocat","repo":"Hello-World"}]}]

# Data stores.
DATABASE_URL=postgres://teamhealth:teamhealth@localhost:5432/teamhealth
REDIS_URL=redis://localhost:6379

# Auth. Leave AUTH_DISABLED unset in production and configure OIDC.
# AUTH_DISABLED=true
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
AUTH_SECRET=
ORIGIN=http://localhost:3000
